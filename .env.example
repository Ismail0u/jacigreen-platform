# ── Base de données ──────────────────────────────
DATABASE_URL=postgresql+asyncpg://jacigreen:password@localhost:5432/jacigreen
POSTGRES_DB=jacigreen
POSTGRES_USER=jacigreen
POSTGRES_PASSWORD=change_me_in_prod

# ── Redis ────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Auth JWT ────────────────────────────────────
# Générer avec : openssl rand -hex 32
SECRET_KEY=change_me_with_openssl_rand_hex_32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Storage S3 (Supabase) ────────────────────────
STORAGE_BUCKET=jacigreen-photos
